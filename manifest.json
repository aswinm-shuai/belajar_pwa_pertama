{
  "id": "/belajar_pwa_pertama/",
  "name": "Subflow",
  "short_name": "Subflow",
  "description": "Aplikasi Manajemen Customer Langganan Aplikasi Premium",
  "start_url": "/belajar_pwa_pertama/index.html",
  "scope": "/belajar_pwa_pertama/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#4F46E5",
  "theme_color": "#4F46E5",
  "orientation": "portrait-primary",
  "lang": "id",
  "dir": "ltr",
  "categories": ["productivity", "utilities", "business", "finance"],
  "handle_links": "preferred",

  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://subflow-web-8070c.web.app/belajar_pwa_pertama/manifest.json",
      "id": "com.subflow.app"
    }
  ],

  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",

  "launch_handler": {
    "client_mode": "focus-existing"
  },

  "edge_side_panel": {
    "preferred_width": 400
  },

  "scope_extensions": [
    {
      "origin": "https://subflow-web-8070c.web.app"
    }
  ],

  "widgets": [
    {
      "name": "Subflow Widget",
      "description": "Ringkasan langganan aktif kamu",
      "tag": "subflow-summary",
      "template": "subflow-widget",
      "ms_ac_template": "/belajar_pwa_pertama/widgets/widget-template.json",
      "data": "/belajar_pwa_pertama/widgets/widget-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "/belajar_pwa_pertama/icons/screenshot dashbord.png",
          "sizes": "1080x1920",
          "label": "Widget Dashboard Subflow"
        }
      ],
      "icons": [
        {
          "src": "/belajar_pwa_pertama/icons/logo subflow 192x192.png",
          "sizes": "192x192"
        }
      ],
      "auth": false,
      "update": 3600
    }
  ],

  "note_taking": {
    "new_note_url": "/belajar_pwa_pertama/index.html#add-customer"
  },

  "icons": [
    {
      "src": "/belajar_pwa_pertama/icons/logo subflow 192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/belajar_pwa_pertama/icons/logo subflow 512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/belajar_pwa_pertama/icons/logo subflow 192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/belajar_pwa_pertama/icons/logo subflow 512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "screenshots": [
    {
      "src": "/belajar_pwa_pertama/icons/screensot master (1).png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Halaman Utama Subflow"
    },
    {
      "src": "/belajar_pwa_pertama/icons/screenshot dashbord.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Dashboard Subflow"
    }
  ],

  "shortcuts": [
    {
      "name": "Buka Beranda",
      "short_name": "Home",
      "description": "Kembali ke halaman utama Subflow",
      "url": "/belajar_pwa_pertama/index.html",
      "icons": [
        {
          "src": "/belajar_pwa_pertama/icons/logo subflow 192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Tambah Transaksi",
      "short_name": "Transaksi",
      "description": "Tambah transaksi baru",
      "url": "/belajar_pwa_pertama/index.html#transaksi",
      "icons": [
        {
          "src": "/belajar_pwa_pertama/icons/logo subflow 192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],

  "share_target": {
    "action": "/belajar_pwa_pertama/share-target.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "file_handlers": [
    {
      "action": "/belajar_pwa_pertama/index.html",
      "accept": {
        "text/csv": [".csv"],
        "application/json": [".json"]
      }
    }
  ],

  "protocol_handlers": [
    {
      "protocol": "web+subflow",
      "url": "/belajar_pwa_pertama/index.html?url=%s"
    }
  ]
}
