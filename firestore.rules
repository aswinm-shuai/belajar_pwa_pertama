rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Izinkan publik membaca data user (untuk mengambil Nama Store & WA)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Izinkan publik membaca daftar Paket
    match /pakets/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. Izinkan publik membaca & menulis (untuk membuat pesanan & klaim baru dari Landing Page)
    match /customers/{userId} {
      allow read, write: if true;
    }

    match /transaksis/{userId} {
      allow read, write: if true;
    }

    match /warrantyClaims/{userId} {
      allow read, write: if true;
    }

    // 4. Koleksi klaim garansi
    match /warranty_claims/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // 5. Koleksi live orders
    match /live_orders/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // 6. Default: hanya user login yang bisa akses selain yang di atas
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
